generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SENIOR
  MEMBER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  avatarUrl String?
  googleId  String   @unique
  role      Role     @default(MEMBER)
  year      Int
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessionsCreated Session[]

  @@map("users")
}

enum YearTarget {
  FIRST
  SECOND
  THIRD
  FOURTH
  ALL
}

model Session {
  id            String     @id @default(uuid())
  title         String
  speakerName   String
  speakerBio    String?
  description   String
  date          DateTime
  venue         String
  recordingUrl  String?
  slidesUrl     String?
  tags          String[]
  yearTarget    YearTarget @default(ALL)
  createdBy     String
  creator       User       @relation(fields: [createdBy], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("sessions")
}